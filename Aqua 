		Track.Parent = SliderFrame
		addCorner(Track, 3)
		
		local Fill = Instance.new("Frame")
		Fill.Size = UDim2.new(((default or min) - min) / (max - min), 0, 1, 0)
		Fill.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
		Fill.BorderSizePixel = 0
		Fill.Parent = Track
		addCorner(Fill, 3)
		
		local SliderKnob = Instance.new("Frame")
		SliderKnob.Size = UDim2.new(0, 10, 0, 10)
		SliderKnob.Position = UDim2.new(1, -5, 0.5, -5)
		SliderKnob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		SliderKnob.Parent = Fill
		addCorner(SliderKnob, 5)
		addStroke(SliderKnob, Color3.fromRGB(0,200,255), 1, 0.3)
		
		local function updateSlider(input)
			local absWidth = Track.AbsoluteSize.X
			local absPos = Track.AbsolutePosition.X
			local relX = math.clamp(input.Position.X - absPos, 0, absWidth)
			local percent = relX / absWidth
			local rawVal = min + (percent * (max - min))
			local finalVal = math.floor(rawVal * 100) / 100
			
			TweenService:Create(Fill, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(percent, 0, 1, 0)}):Play()
			ValueLabel.Text = tostring(finalVal)
			callback(finalVal)
		end
		
		local sliding = false
		Track.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				sliding = true
				playSound(SFX.Click, 0.35, 1.1)
				updateSlider(input)
				TweenService:Create(SliderKnob, TweenInfo.new(0.12), {Size = UDim2.new(0, 14, 0, 14), Position = UDim2.new(1, -7, 0.5, -7), BackgroundColor3 = Color3.fromRGB(0,200,255)}):Play()
			end
		end)
		
		UserInputService.InputChanged:Connect(function(input)
			if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				updateSlider(input)
			end
		end)
		
		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				sliding = false
				TweenService:Create(SliderKnob, TweenInfo.new(0.12), {Size = UDim2.new(0, 10, 0, 10), Position = UDim2.new(1, -5, 0.5, -5), BackgroundColor3 = Color3.fromRGB(255,255,255)}):Play()
			end
		end)
