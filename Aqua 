	local function createKeybindEngine(parentFrame, name, defaultKey, callback)
		local currentKey = defaultKey or Enum.KeyCode.E
		local binding = false
		local isToggleMode = false
		local toggleState = false
		
		local info = debug.info(callback, "a")
		if info and info > 0 then isToggleMode = true end
		
		local BindBtn = Instance.new("TextButton")
		BindBtn.Size = UDim2.new(0, 65, 0, 18)
		BindBtn.Position = UDim2.new(1, -70, 0.5, -9)
		BindBtn.BackgroundColor3 = Color3.fromRGB(24, 30, 38)
		BindBtn.Text = currentKey.Name
		BindBtn.TextColor3 = Color3.fromRGB(0, 200, 255)
		BindBtn.Font = Enum.Font.SourceSansBold
		BindBtn.TextSize = 11
		BindBtn.AutoButtonColor = false
		BindBtn.Parent = parentFrame
		addCorner(BindBtn, 4)
		addStroke(BindBtn, Color3.fromRGB(0, 200, 255), 1, 0.7)
		
		BindBtn.MouseButton1Click:Connect(function()
			binding = true
			BindBtn.Text = "..."
			BindBtn:FindFirstChildOfClass("UIStroke").Color = Color3.fromRGB(255, 255, 255)
			playSound(SFX.Click, 0.4)
		end)
		
		UserInputService.InputBegan:Connect(function(input, gpe)
			if gpe then return end
			if binding then
				if input.UserInputType == Enum.UserInputType.Keyboard then
					currentKey = input.KeyCode
					BindBtn.Text = currentKey.Name
					BindBtn:FindFirstChildOfClass("UIStroke").Color = Color3.fromRGB(0, 200, 255)
					binding = false
					playSound(SFX.ToggleOn, 0.4)
				end
			else
				if input.KeyCode == currentKey then
					playSound(SFX.Click, 0.45, 1.05)
					TweenService:Create(BindBtn, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, 72, 0, 22), Position = UDim2.new(1, -74, 0.5, -11)}):Play()
					task.delay(0.1, function()
						TweenService:Create(BindBtn, TweenInfo.new(0.1), {Size = UDim2.new(0, 65, 0, 18), Position = UDim2.new(1, -70, 0.5, -9)}):Play()
					end)
					if isToggleMode then
						toggleState = not toggleState
						callback(toggleState)
					else
						callback()
					end
				end
			end
		end)
		return BindBtn
	end

