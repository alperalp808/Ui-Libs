	local Dl = Instance.new("TextLabel")
	Dl.Size = UDim2.new(1, -20, 0, 30)
	Dl.Position = UDim2.new(0, 10, 0, 24)
	Dl.BackgroundTransparency = 1
	Dl.Text = description or ""
	Dl.Font = Enum.Font.SourceSans
	Dl.TextSize = 13
	Dl.TextColor3 = Color3.fromRGB(180, 185, 190)
	Dl.TextTransparency = 1
	Dl.TextXAlignment = Enum.TextXAlignment.Left
	Dl.TextYAlignment = Enum.TextYAlignment.Top
	Dl.TextWrapped = true
	Dl.Parent = Box
	
	playSound(SFX.Notify, 0.5)
	
	TweenService:Create(Box, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 0.2}):Play()
	TweenService:Create(MainStroke, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Transparency = 0.4}):Play()
	TweenService:Create(GlowLine, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0}):Play()
	TweenService:Create(Tl, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()
	TweenService:Create(Dl, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()
	
	TweenService:Create(GlowLine, TweenInfo.new(duration, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 0, 2)}):Play()
	
	task.delay(duration, function()
		local info = TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
		TweenService:Create(Box, info, {Position = UDim2.new(1, 320, 0, 0), BackgroundTransparency = 1}):Play()
		TweenService:Create(MainStroke, info, {Transparency = 1}):Play()
		TweenService:Create(GlowLine, info, {BackgroundTransparency = 1}):Play()
		TweenService:Create(Tl, info, {TextTransparency = 1}):Play()
		local finalTw = TweenService:Create(Dl, info, {TextTransparency = 1})
		finalTw:Play()
		finalTw.Completed:Connect(function() Box:Destroy() end)
	end)
end

