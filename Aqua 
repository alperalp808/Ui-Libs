	-- SLIDER CONSTRUCTOR (Fully fluid for mobile touch)
	function elements:AddSlider(name, min, max, default, callback)
		local SliderFrame = Instance.new("Frame")
		SliderFrame.Size = UDim2.new(0.92, 0, 0, 38)
		SliderFrame.BackgroundTransparency = 1
		SliderFrame.Parent = SectionFrame
		
		local Label = Instance.new("TextLabel")
		Label.Size = UDim2.new(1, 0, 0, 15)
		Label.BackgroundTransparency = 1
		Label.Text = name
		Label.TextColor3 = Color3.fromRGB(180, 180, 180)
		Label.Font = Enum.Font.SourceSans
		Label.TextSize = 13
		Label.TextXAlignment = Enum.TextXAlignment.Left
		Label.Parent = SliderFrame
		
		local ValueLabel = Instance.new("TextLabel")
		ValueLabel.Size = UDim2.new(1, 0, 0, 15)
		ValueLabel.BackgroundTransparency = 1
		ValueLabel.Text = tostring(default or min)
		ValueLabel.TextColor3 = Color3.fromRGB(0, 200, 255)
		ValueLabel.Font = Enum.Font.SourceSansBold
		ValueLabel.TextSize = 13
		ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
		ValueLabel.Parent = SliderFrame
		
		local Track = Instance.new("TextButton")
		Track.Size = UDim2.new(1, 0, 0, 6)
		Track.Position = UDim2.new(0, 0, 0, 24)
		Track.BackgroundColor3 = Color3.fromRGB(40, 48, 56)
		Track.Text = ""
		Track.AutoButtonColor = false
		Track.Parent = SliderFrame
		
		local Fill = Instance.new("Frame")
		Fill.Size = UDim2.new(((default or min) - min) / (max - min), 0, 1, 0)
		Fill.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
		Fill.BorderSizePixel = 0
		Fill.Parent = Track
		
		-- Slide Handler (PC + Mobile Smooth Tracking)
		local function processSlide(input)
			local absWidth = Track.AbsoluteSize.X
			local absPos = Track.AbsolutePosition.X
			local relX = math.clamp(input.Position.X - absPos, 0, absWidth)
			local percent = relX / absWidth
			local rawVal = min + (percent * (max - min))
			local finalVal = math.floor(rawVal * 100) / 100 -- 2 decimal places max
			
			TweenService:Create(Fill, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(percent, 0, 1, 0)}):Play()
			ValueLabel.Text = tostring(finalVal)
			callback(finalVal)
		end
		
		local sliding = false
		Track.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				sliding = true
				playSound(Sounds.Click, 0.3)
				processSlide(input)
			end
		end)
		
		UserInputService.InputChanged:Connect(function(input)
			if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				processSlide(input)
			end
		end)
		
		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				sliding = false
			end
		end)
	end
	
