-- SMOOTH DRAG & RESIZE IMPLEMENTATION
function Menu:SetupDragAndResize(dragFrame, resizeGrip)
	local main = self.MainFrame
	
	-- Dragging Logic
	local dragging, dragInput, dragStart, startPos
	local function updateDrag(input)
		local delta = input.Position - dragStart
		TweenService:Create(main, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		}):Play()
	end
	
	dragFrame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = main.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)
	
	dragFrame.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)
	
	-- Resizing Logic
	local resizing, resizeStart, startSize
	local function updateResize(input)
		local delta = input.Position - resizeStart
		local newX = math.clamp(startSize.X + delta.X, 400, 1000)
		local newY = math.clamp(startSize.Y + delta.Y, 300, 700)
		main.Size = UDim2.new(0, newX, 0, newY)
	end
	
	resizeGrip.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			resizing = true
			resizeStart = input.Position
			startSize = Vector2.new(main.Size.X.Offset, main.Size.Y.Offset)
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then resizing = false end
			end)
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if dragging and input == dragInput then
			updateDrag(input)
		elseif resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateResize(input)
		end
	end)
end

-- TAB SYSTEM
function Menu:AddTab(name)
	local TabButton = Instance.new("TextButton")
	TabButton.Size = UDim2.new(0, 100, 1, 0)
	TabButton.BackgroundColor3 = Color3.fromRGB(22, 26, 32)
	TabButton.BorderSizePixel = 0
	TabButton.Text = name
	TabButton.Font = Enum.Font.SourceSans
	TabButton.TextSize = 14
	TabButton.TextColor3 = Color3.fromRGB(150, 150, 150)
	TabButton.Parent = self.MainFrame.TabBar
	
	local TabPage = Instance.new("Frame")
	TabPage.Size = UDim2.new(1, 0, 1, 0)
	TabPage.BackgroundTransparency = 1
	TabPage.Visible = false
	TabPage.Parent = self.Container
	
	-- Left & Right Section Masters
	local LeftZone = Instance.new("ScrollingFrame")
	LeftZone.Size = UDim2.new(0.5, -5, 1, 0)
	LeftZone.BackgroundTransparency = 1
	LeftZone.ScrollBarThickness = 2
	LeftZone.ScrollBarImageColor3 = Color3.fromRGB(0, 200, 255)
	LeftZone.Parent = TabPage
	
	local RightZone = LeftZone:Clone()
	RightZone.Position = UDim2.new(0.5, 5, 0, 0)
	RightZone.Parent = TabPage
	
	local LList = Instance.new("UIListLayout")
	LList.SortOrder = Enum.SortOrder.LayoutOrder
	LList.Padding = UDim.new(0, 10)
	LList.Parent = LeftZone
	
	local RList = LList:Clone()
	RList.Parent = RightZone
	
	-- Auto Canvas Size adjustment
	LList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() LeftZone.CanvasSize = UDim2.new(0,0,0, LList.AbsoluteContentSize.Y + 10) end)
	RList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() RightZone.CanvasSize = UDim2.new(0,0,0, RList.AbsoluteContentSize.Y + 10) end)

	local tabData = {Left = LeftZone, Right = RightZone, Button = TabButton, Page = TabPage}
	
	TabButton.MouseButton1Click:Connect(function()
		playSound(Sounds.Click, 0.4)
		for _, t in pairs(self.Tabs) do
			t.Page.Visible = false
			t.Button.TextColor3 = Color3.fromRGB(150, 150, 150)
			t.Button.BackgroundColor3 = Color3.fromRGB(22, 26, 32)
		end
		TabPage.Visible = true
		TabButton.TextColor3 = Color3.fromRGB(0, 200, 255)
		TabButton.BackgroundColor3 = Color3.fromRGB(28, 34, 42)
	end)
	
	TabButton.MouseEnter:Connect(function() playSound(Sounds.Hover, 0.2) end)
	
	table.insert(self.Tabs, tabData)
	if #self.Tabs == 1 then
		TabPage.Visible = true
		TabButton.TextColor3 = Color3.fromRGB(0, 200, 255)
		TabButton.BackgroundColor3 = Color3.fromRGB(28, 34, 42)
	end
	
	return tabData
end

