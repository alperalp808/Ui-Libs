		DiagnosticFrame.Visible = not minimized
	end)
	
	self.Tabs = {}
	self.GlobalToggleKey = Enum.KeyCode.RightShift
	self.MenuVisible = true
	self.IsTweeningVisibility = false
	
	if keyName ~= nil or showButton ~= nil then
		self:SetupGlobalToggle(keyName, showButton)
	end
	
	return self
end

function Menu:SetupDragAndResize(dragFrame, resizeGrip)
	local main = self.CanvasGroup
	local dragging, dragInput, dragStart, startPos
	
	dragFrame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = main.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)
	dragFrame.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)
	
	local resizing, resizeStart, startSize
	resizeGrip.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			resizing = true
			resizeStart = input.Position
			startSize = Vector2.new(main.Size.X.Offset, main.Size.Y.Offset)
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then resizing = false end
			end)
		end
	end)
	
	UserInputService.InputChanged:Connect(function(input)
		if dragging and input == dragInput then
			local delta = input.Position - dragStart
			TweenService:Create(main, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
			}):Play()
		elseif resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - resizeStart
			local newX = math.clamp(startSize.X + delta.X, 600, 1300)
			local newY = math.clamp(startSize.Y + delta.Y, 360, 900)
			TweenService:Create(main, TweenInfo.new(0.05, Enum.EasingStyle.Linear), {Size = UDim2.new(0, newX, 0, newY)}):Play()
		end
	end)
end

function Menu:SetupGlobalToggle(keyName, showButton)
	if keyName then
		pcall(function()
			self.GlobalToggleKey = Enum.KeyCode[keyName]
		end)
	end

	local function setVisibilityAnimated(state)
		if self.IsTweeningVisibility then return end
		self.IsTweeningVisibility = true
		self.MenuVisible = state
		
		local info = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		
		if state then
			self.CanvasGroup.Visible = true
			playSound(SFX.Open, 0.45)
			local tw = TweenService:Create(self.CanvasGroup, info, {GroupTransparency = 0})
			tw:Play()
			tw.Completed:Connect(function()
				self.IsTweeningVisibility = false
			end)
		else
			playSound(SFX.Close, 0.45)
			local tw = TweenService:Create(self.CanvasGroup, info, {GroupTransparency = 1})
			tw:Play()
			tw.Completed:Connect(function()
				self.CanvasGroup.Visible = false
				self.IsTweeningVisibility = false
			end)
		end
	end

	if not self.ToggleConnection then
		self.ToggleConnection = UserInputService.InputBegan:Connect(function(input, gpe)
			if gpe then return end
			if input.KeyCode == self.GlobalToggleKey then
				setVisibilityAnimated(not self.MenuVisible)
			end
		end)
	end

	if showButton and not self.PersistentButton then
		local TargetGui = LocalPlayer:WaitForChild("PlayerGui"):FindFirstChild("Aqua_PersistentControls")
		if not TargetGui then
			TargetGui = Instance.new("ScreenGui")
			TargetGui.Name = "Aqua_PersistentControls"
			TargetGui.ResetOnSpawn = false
			TargetGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
			TargetGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
		end
		self.PersistentGui = TargetGui

		local PButton = Instance.new("TextButton")
		PButton.Size = UDim2.new(0, 36, 0, 36)
		PButton.Position = UDim2.new(0, 15, 0, 120)
		PButton.BackgroundColor3 = Color3.fromRGB(12, 16, 20)
		PButton.BackgroundTransparency = 0.4
		PButton.Text = "🌊"
		PButton.TextColor3 = Color3.fromRGB(0, 200, 255)
		PButton.Font = Enum.Font.SourceSansBold
		PButton.TextSize = 18
		PButton.AutoButtonColor = false
		PButton.ZIndex = 999
		PButton.Parent = TargetGui
		self.PersistentButton = PButton

		addCorner(PButton, 18)
		addStroke(PButton, Color3.fromRGB(0, 200, 255), 1.2, 0.5)

		PButton.MouseEnter:Connect(function()
			playSound(SFX.Hover, 0.2)
			TweenService:Create(PButton, TweenInfo.new(0.2), {BackgroundTransparency = 0.1, TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
		end)
		PButton.MouseLeave:Connect(function()
			TweenService:Create(PButton, TweenInfo.new(0.2), {BackgroundTransparency = 0.4, TextColor3 = Color3.fromRGB(0, 200, 255)}):Play()
		end)

		PButton.MouseButton1Click:Connect(function()
			setVisibilityAnimated(not self.MenuVisible)
		end)

		local btnDragging, btnDragInput, btnDragStart, btnStartPos
		PButton.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				btnDragging = true
				btnDragStart = input.Position
				btnStartPos = PButton.Position
				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then btnDragging = false end
				end)
			end
		end)
		PButton.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
				btnDragInput = input
			end
		end)
		UserInputService.InputChanged:Connect(function(input)
			if btnDragging and input == btnDragInput then
				local delta = input.Position - btnDragStart
				PButton.Position = UDim2.new(btnStartPos.X.Scale, btnStartPos.X.Offset + delta.X, btnStartPos.Y.Scale, btnStartPos.Y.Offset + delta.Y)
			end
		end)
	end
end

