		BindFrame.BackgroundTransparency = 1
		BindFrame.Parent = SectionFrame
		
		local Label = Instance.new("TextLabel")
		Label.Size = UDim2.new(0.6, 0, 1, 0)
		Label.BackgroundTransparency = 1
		Label.Text = name
		Label.TextColor3 = Color3.fromRGB(170, 175, 180)
		Label.Font = Enum.Font.SourceSans
		Label.TextSize = 14
		Label.TextXAlignment = Enum.TextXAlignment.Left
		Label.Parent = BindFrame
		
		createKeybindEngine(BindFrame, name, defaultKey, callback)
	end
	
	function elements:AddDropdown(name, list, isMulti, callback)
		local dropped = false
		local selectedItems = {}
		if not isMulti then selectedItems = {list[1] or "None"} end
		
		local DropFrame = Instance.new("Frame")
		DropFrame.Size = UDim2.new(0.94, 0, 0, 48)
		DropFrame.BackgroundTransparency = 1
		DropFrame.ZIndex = 5
		DropFrame.Parent = SectionFrame
		
		local Label = Instance.new("TextLabel")
		Label.Size = UDim2.new(1, 0, 0, 16)
		Label.BackgroundTransparency = 1
		Label.Text = name
		Label.TextColor3 = Color3.fromRGB(150, 155, 160)
		Label.Font = Enum.Font.SourceSans
		Label.TextSize = 13
		Label.TextXAlignment = Enum.TextXAlignment.Left
		Label.Parent = DropFrame
		
		local ActionBtn = Instance.new("TextButton")
		ActionBtn.Size = UDim2.new(1, 0, 0, 26)
		ActionBtn.Position = UDim2.new(0, 0, 0, 20)
		ActionBtn.BackgroundColor3 = Color3.fromRGB(24, 30, 38)
		ActionBtn.Text = "  " .. (isMulti and "Multiple Options..." or tostring(selectedItems[1]))
		ActionBtn.TextColor3 = Color3.fromRGB(230, 235, 240)
		ActionBtn.Font = Enum.Font.SourceSans
		ActionBtn.TextSize = 13
		ActionBtn.TextXAlignment = Enum.TextXAlignment.Left
		ActionBtn.AutoButtonColor = false
		ActionBtn.ZIndex = 6
		ActionBtn.Parent = DropFrame
		addCorner(ActionBtn, 5)
		addStroke(ActionBtn, Color3.fromRGB(255,255,255), 1, 0.94)
		
		local Arrow = Instance.new("TextLabel")
		Arrow.Size = UDim2.new(0, 24, 1, 0)
		Arrow.Position = UDim2.new(1, -24, 0, 0)
		Arrow.BackgroundTransparency = 1
		Arrow.Text = "▼"
		Arrow.TextColor3 = Color3.fromRGB(120, 125, 130)
		Arrow.Font = Enum.Font.SourceSansBold
		Arrow.TextSize = 10
		Arrow.ZIndex = 7
		Arrow.Parent = ActionBtn
		
		local ListContainer = Instance.new("Frame")
		ListContainer.Size = UDim2.new(1, 0, 0, 0)
		ListContainer.Position = UDim2.new(0, 0, 1, 2)
		ListContainer.BackgroundColor3 = Color3.fromRGB(16, 20, 26)
		ListContainer.ClipsDescendants = true
		ListContainer.ZIndex = 50
		ListContainer.Parent = ActionBtn
		addCorner(ListContainer, 5)
		addStroke(ListContainer, Color3.fromRGB(0, 200, 255), 1, 0.7)
		
		local ListLayout = Instance.new("UIListLayout")
		ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
		ListLayout.Parent = ListContainer
		
		local function toggleDropdown()
			dropped = not dropped
			playSound(SFX.Click, 0.4)
			
			if dropped then
				parentZone.ZIndex = 10
				SectionFrame.ZIndex = 10
				DropFrame.ZIndex = 10
				ActionBtn.ZIndex = 11
			else
				task.delay(0.25, function()
					if not dropped then
						parentZone.ZIndex = 1
						SectionFrame.ZIndex = 2
						DropFrame.ZIndex = 5
						ActionBtn.ZIndex = 6
					end
				end)
			end
			
			local targetHeight = dropped and math.clamp(#list * 24, 0, 160) or 0
			TweenService:Create(ListContainer, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, targetHeight)}):Play()
			TweenService:Create(Arrow, TweenInfo.new(0.2), {Rotation = dropped and 180 or 0, TextColor3 = dropped and Color3.fromRGB(0, 200, 255) or Color3.fromRGB(120, 125, 130)}):Play()
		end
		
		ActionBtn.MouseButton1Click:Connect(toggleDropdown)
		
		for _, item in pairs(list) do
			local ItemBtn = Instance.new("TextButton")
			ItemBtn.Size = UDim2.new(1, 0, 0, 24)
			ItemBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
			ItemBtn.BackgroundTransparency = 1
			ItemBtn.Text = "  " .. tostring(item)
			ItemBtn.TextColor3 = table.find(selectedItems, item) and Color3.fromRGB(0,200,255) or Color3.fromRGB(190, 195, 200)
			ItemBtn.Font = Enum.Font.SourceSans
			ItemBtn.TextSize = 13
			ItemBtn.TextXAlignment = Enum.TextXAlignment.Left
			ItemBtn.ZIndex = 55
			ItemBtn.AutoButtonColor = false
			ItemBtn.Parent = ListContainer
			
			ItemBtn.MouseEnter:Connect(function()
				if not table.find(selectedItems, item) then
					TweenService:Create(ItemBtn, TweenInfo.new(0.15), {BackgroundTransparency = 0.9, TextColor3 = Color3.fromRGB(255,255,255)}):Play()
				end
			end)
			ItemBtn.MouseLeave:Connect(function()
				if not table.find(selectedItems, item) then
					TweenService:Create(ItemBtn, TweenInfo.new(0.15), {BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(190, 195, 200)}):Play()
				end
			end)
			
			ItemBtn.MouseButton1Click:Connect(function()
				if isMulti then
					local idx = table.find(selectedItems, item)
					if idx then
						table.remove(selectedItems, idx)
						TweenService:Create(ItemBtn, TweenInfo.new(0.15), {TextColor3 = Color3.fromRGB(190,195,200), BackgroundTransparency = 1}):Play()
					else
						table.insert(selectedItems, item)
						TweenService:Create(ItemBtn, TweenInfo.new(0.15), {TextColor3 = Color3.fromRGB(0, 200, 255), BackgroundTransparency = 0.85}):Play()
					end
					callback(selectedItems)
				else
					selectedItems = {item}
					ActionBtn.Text = "  " .. tostring(item)
					toggleDropdown()
					callback(item)
				end
			end)
		end
	end
	
	function elements:AddColorpicker(name, defaultColor, callback)
		local opened = false
		local color = defaultColor or Color3.fromRGB(0, 200, 255)
		
		local CpFrame = Instance.new("Frame")
		CpFrame.Size = UDim2.new(0.94, 0, 0, 30)
		CpFrame.BackgroundTransparency = 1
		CpFrame.Parent = SectionFrame
		
		local Label = Instance.new("TextLabel")
		Label.Size = UDim2.new(0.6, 0, 1, 0)
		Label.BackgroundTransparency = 1
		Label.Text = name
		Label.TextColor3 = Color3.fromRGB(170, 175, 180)
		Label.Font = Enum.Font.SourceSans
		Label.TextSize = 14
		Label.TextXAlignment = Enum.TextXAlignment.Left
		Label.Parent = CpFrame
		
		local BoxTrigger = Instance.new("TextButton")
		BoxTrigger.Size = UDim2.new(0, 34, 0, 18)
		BoxTrigger.Position = UDim2.new(1, -34, 0.5, -9)
		BoxTrigger.BackgroundColor3 = color
		BoxTrigger.Text = ""
		BoxTrigger.AutoButtonColor = false
		BoxTrigger.Parent = CpFrame
		addCorner(BoxTrigger, 4)
		addStroke(BoxTrigger, Color3.fromRGB(255,255,255), 1, 0.6)
		
		local PaletteContainer = Instance.new("Frame")
		PaletteContainer.Size = UDim2.new(0, 160, 0, 24)
		PaletteContainer.Position = UDim2.new(1, -165, 1, 4)
		PaletteContainer.BackgroundColor3 = Color3.fromRGB(20, 24, 30)
		PaletteContainer.ClipsDescendants = true
		PaletteContainer.Visible = false
		PaletteContainer.ZIndex = 15
		PaletteContainer.Parent = BoxTrigger
		addCorner(PaletteContainer, 5)
		addStroke(PaletteContainer, Color3.fromRGB(0, 200, 255), 1, 0.5)
		
		local UILayout = Instance.new("UIListLayout")
		UILayout.FillDirection = Enum.FillDirection.Horizontal
		UILayout.SortOrder = Enum.SortOrder.LayoutOrder
		UILayout.Parent = PaletteContainer
		
		local presetColors = {
			Color3.fromRGB(255,0,0), Color3.fromRGB(255,127,0), Color3.fromRGB(255,255,0),
			Color3.fromRGB(0,255,0), Color3.fromRGB(0,200,255), Color3.fromRGB(0,0,255),
			Color3.fromRGB(139,0,255), Color3.fromRGB(255,255,255), Color3.fromRGB(0,0,0)
		}
		
		BoxTrigger.MouseButton1Click:Connect(function()
			opened = not opened
			playSound(SFX.Click, 0.4)
			PaletteContainer.Visible = opened
		end)
		
		for i, pColor in pairs(presetColors) do
			local ColorBlock = Instance.new("TextButton")
			ColorBlock.Size = UDim2.new(1/#presetColors, 0, 1, 0)
			ColorBlock.BackgroundColor3 = pColor
			ColorBlock.Text = ""
			ColorBlock.ZIndex = 16
			ColorBlock.Parent = PaletteContainer
			
			ColorBlock.MouseButton1Click:Connect(function()
				color = pColor
				BoxTrigger.BackgroundColor3 = color
				opened = false
				PaletteContainer.Visible = false
				playSound(SFX.ToggleOn, 0.4)
				callback(color)
			end)
		end
	end
	
	return elements
end

return Menu
